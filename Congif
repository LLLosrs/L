package com.osrsnamewatcher;

import net.runelite.client.config.Config;
import net.runelite.client.config.ConfigGroup;
import net.runelite.client.config.ConfigItem;

@ConfigGroup("osrsnamewatcher")
public interface OsrsNameWatcherConfig extends Config
{
	@ConfigItem(
		keyName = "watchNames",
		name = "Watch names",
		description = "Comma-separated or line-separated names to watch. Empty = log every detected name change.",
		position = 1
	)
	default String watchNames()
	{
		return "";
	}

	@ConfigItem(
		keyName = "outputFile",
		name = "Output file",
		description = "Optional custom JSONL output path. Leave empty to use the default .runelite file.",
		position = 2
	)
	default String outputFile()
	{
		return "";
	}
}
